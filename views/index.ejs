<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="canonical" href="<%= canonical %>">
    <link rel="icon" type="image/png" href="favicon.png">
    <!-- SEO & Meta Tags -->
    <meta name="description" content="<%= description %>">
    <meta name="keywords" content="JEE Main, NEET, Mock Test Simulator, PDF question extractor, auto slice questions, CBT practice, IIT JEE prep, NEET prep">
    <meta name="author" content="JEE/NEET Prep Tools">
    <meta property="og:title" content="JEE/NEET Auto PDF Mock Test Simulator">
    <meta property="og:description" content="Turn your PDFs into interactive Computer Based Tests (CBT). Client-side, serverless, secure.">
    <meta property="og:type" content="website">

    <!-- Vercel Speed Insights -->
    <script>
        window.si = window.si || function () { (window.siq = window.siq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/speed-insights/script.js"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    </noscript>

    <!-- Local CSS -->
    <style><%- include('../public/styles.css') %></style>
    <script>
        // Check for saved theme preference or use system preference safely
        try {
            if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        } catch (e) {
            // Safari private mode might throw error, fallback to system preference
            if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.classList.add('dark');
            }
        }
    </script>
    
    <!-- PeerJS -->
    <script defer src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>

    <!-- PDF.js -->
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

    <!-- JSZip & FileSaver -->
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <style>
        .margin-line {
            cursor: ns-resize;
        }
        .nta-not-visited {
            background-color: #f3f4f6;
            color: #000;
        }
        .nta-not-answered {
            background-color: #d9534f;
            color: white;
            clip-path: polygon(0 0, 100% 0, 100% 75%, 50% 100%, 0 75%);
            border-radius: 0 0 10% 10%;
        }
        .nta-answered {
            background-color: #5cb85c;
            color: white;
            border-radius: 100% 100% 0 0;
            clip-path: polygon(50% 0%, 100% 25%, 100% 100%, 0% 100%, 0% 25%);
        }
        .nta-marked {
            background-color: #5bc0de;
            color: white;
            border-radius: 9999px;
        }
        .nta-answered-marked {
            background-color: #5bc0de;
            color: white;
            border-radius: 9999px;
        }
        .margin-line::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            height: 2px;
            background-color: rgb(239, 68, 68);
        }
        .margin-line:hover::after {
            background-color: rgb(220, 38, 38);
            height: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* NTA Palette Shapes and Colors */
        .nta-not-visited { background-color: #e5e7eb; border-color: #d1d5db; color: #374151; }
        .nta-not-answered { background-color: #F28C28; border-color: #d97a22; color: white; border-radius: 0 0 10px 10px; }
        .nta-answered { background-color: #22c55e; border-color: #16a34a; color: white; border-radius: 10px 10px 0 0; }
        .nta-marked { background-color: #9333ea; border-color: #7e22ce; color: white; border-radius: 50%; }
        .nta-answered-marked { background-color: #9333ea; border-color: #7e22ce; color: white; border-radius: 50%; }
        .nta-wrong { background-color: #ef4444; border-color: #dc2626; color: white; border-radius: 10px 10px 0 0; }

        /* GenZ Animations & Mesh */
        @keyframes blob {
            0% { transform: translate(0px, 0px) scale(1); }
            33% { transform: translate(30px, -50px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
            100% { transform: translate(0px, 0px) scale(1); }
        }
        .animate-blob {
            animation: blob 7s infinite;
        }
        .animation-delay-2000 {
            animation-delay: 2s;
        }
        .animation-delay-4000 {
            animation-delay: 4s;
        }
        
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .dark .glass-panel {
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
    <link rel="preload" href="logo.png" as="image">

    <!-- Safari & Apple Specific Meta -->
    <link rel="apple-touch-icon" href="/logo.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#0a192f">

    <!-- Universal Social/Search Cards (Brave, Twitter, etc.) -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title %>">
    <meta name="twitter:description" content="<%= description %>">
    <meta name="twitter:image" content="https://pdftopractice.in/logo.png">
    <meta property="og:image" content="https://pdftopractice.in/logo.png">

</head>
<body class="bg-slate-50 dark:bg-[#0B1120] text-gray-900 dark:text-gray-100 font-sans transition-colors duration-200 relative min-h-screen overflow-x-hidden">
    
    <!-- Animated Background Mesh -->
    <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
        <div class="absolute top-0 -left-4 w-72 h-72 bg-purple-300 dark:bg-purple-900/40 rounded-full filter blur-2xl opacity-70 animate-blob"></div>
        <div class="absolute top-0 -right-4 w-72 h-72 bg-pink-300 dark:bg-pink-900/40 rounded-full filter blur-2xl opacity-70 animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-8 left-20 w-72 h-72 bg-blue-300 dark:bg-blue-900/40 rounded-full filter blur-2xl opacity-70 animate-blob animation-delay-4000"></div>
    </div>



    <header class="glass-panel sticky top-0 z-50 shadow-sm transition-colors border-b-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <img src="logo.png" alt="Logo" class="w-10 h-10 rounded-lg">
                <h1 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">PDF to PRACTICE</h1>
            </div>
            <div class="flex items-center space-x-4">
                <button id="themeToggleBtn" aria-label="Toggle Theme" class="p-2 rounded-full bg-gray-100 dark:bg-navy-800 shadow-sm border border-gray-200 dark:border-navy-700 text-yellow-500 dark:text-yellow-400 hover:bg-gray-200 dark:hover:bg-navy-700 transition-colors cursor-pointer" title="Toggle Theme">
                    <svg id="themeIconSun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <svg id="themeIconMoon" class="w-5 h-5 block dark:hidden text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
                <a href="/donate" class="text-sm font-semibold text-gray-700 dark:text-gray-300 hover:text-pink-600 dark:hover:text-pink-400 transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>
                    Support/Donate
                </a>
                <a href="mailto:support@pdftopractice.in" class="text-sm font-semibold text-gray-700 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    Report a Bug
                </a>
                <button id="downloadBtn" class="hidden bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors flex items-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    <span>Download All Crops</span>
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- 1. Upload Zone -->
        <div id="uploadContainer" class="max-w-2xl mx-auto text-center mt-8">
            <div class="flex flex-wrap justify-center gap-3 mb-4">
                <div class="inline-block px-4 py-1.5 rounded-full bg-gradient-to-r from-pink-500/10 to-purple-500/10 dark:from-pink-500/20 dark:to-purple-500/20 border border-pink-500/20 dark:border-pink-500/30">
                    <span class="text-sm font-bold bg-clip-text text-transparent bg-gradient-to-r from-pink-500 to-purple-600 dark:from-pink-400 dark:to-purple-400">✨ NEW: Auto-Extraction AI</span>
                </div>
                <div class="inline-block px-4 py-1.5 rounded-full bg-gradient-to-r from-blue-500/10 to-cyan-500/10 dark:from-blue-500/20 dark:to-cyan-500/20 border border-blue-500/20 dark:border-blue-500/30">
                    <span class="text-sm font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-cyan-600 dark:from-blue-400 dark:to-cyan-400">❤️ 100% Free - Till the end of time</span>
                </div>
            </div>
            <h2 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight leading-tight">
                Transform Coaching PDFs into <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500 dark:from-blue-400 dark:to-cyan-300">CBT Mocks Instantly</span>
            </h2>
            <p class="text-lg text-gray-600 dark:text-gray-400 mb-10 max-w-xl mx-auto">
                Upload your DPPs, PYQs, or assignments. Configure margins to skip headers/footers, and our auto-slicer will turn it into an interactive practice session in seconds.
            </p>
            <div class="flex justify-center relative">
                <!-- Glowing effect behind dropzone -->
                <div class="absolute inset-0 bg-gradient-to-r from-blue-400 to-purple-500 rounded-3xl blur-xl opacity-20 dark:opacity-30"></div>
                
                <!-- Dynamic Drop Zone -->
                <div id="dropZone" class="relative group flex flex-col items-center justify-center w-full max-w-lg h-72 p-6 border-2 border-dashed border-blue-300/50 dark:border-blue-700/50 rounded-3xl glass-panel hover:border-blue-500 dark:hover:border-blue-400 hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-500/20 transition-all duration-300 cursor-pointer overflow-hidden">
                    <input type="file" id="fileInput" accept="application/pdf" aria-label="Upload PDF" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" />
                    <div class="flex flex-col items-center space-y-4">
                        <div id="dropIconContainer" class="p-4 rounded-full bg-gray-100 dark:bg-navy-900 text-gray-500 dark:text-gray-400 group-hover:bg-blue-100 dark:group-hover:bg-blue-900 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                        </div>
                        <div class="text-center transform transition-transform group-hover:-translate-y-1">
                            <p id="dropTextMain" class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-800 to-gray-600 dark:from-white dark:to-gray-300">Upload DPP or PYQ</p>
                            <p id="dropTextSub" class="text-sm text-gray-500 dark:text-gray-400 mt-2 font-medium">Drag & drop or click to browse</p>
                        </div>
                    </div>
                    
                    <!-- Decorative corner blobs for dropzone -->
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-colors"></div>
                    <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-colors"></div>
                    
                    <button id="skipAnswersBtn" class="hidden absolute bottom-4 text-sm text-blue-600 hover:text-blue-800 underline z-30 font-semibold">Skip & Start Scan</button>
                </div>
            </div>
            
            <!-- How to Use Button -->
            <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
                <button id="homeCreateLiveRoomBtn" class="inline-flex items-center justify-center gap-2 bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg transition-transform transform hover:-translate-y-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    Host a Live Practice Room
                </button>
                <a href="https://youtu.be/AYSNQ1UcL7I" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-transform transform hover:-translate-y-1">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M21.582,6.186c-0.23-0.86-0.908-1.538-1.768-1.768C18.254,4,12,4,12,4S5.746,4,4.186,4.418c-0.86,0.23-1.538,0.908-1.768,1.768C2,7.746,2,12,2,12s0,4.254,0.418,5.814c0.23,0.86,0.908,1.538,1.768,1.768C5.746,20,12,20,12,20s6.254,0,7.814-0.418c0.86-0.23,1.538-0.908,1.768-1.768C22,16.254,22,12,22,12S22,7.746,21.582,6.186z M10,15.464V8.536L16,12L10,15.464z"></path></svg>
                    How to Use
                </a>
            </div>
        </div>

        <!-- Bookmarked Questions Section -->
        <div id="bookmarksContainer" class="hidden max-w-5xl mx-auto mt-20">
            <h2 class="text-2xl font-bold mb-6 px-4">Bookmarked Questions</h2>
            <div id="bookmarksList" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 px-4">
                <!-- Bookmark group cards injected here -->
            </div>
        </div>

        <!-- Noted Questions Section -->
        <div id="notedQsContainer" class="hidden max-w-5xl mx-auto mt-12">
            <h2 class="text-2xl font-bold mb-6 px-4">Questions with Notes</h2>
            <div id="notedQsList" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 px-4">
                <!-- Noted Qs card injected here -->
            </div>
        </div>

        <!-- Practice History Section (Visible on Landing Page) -->
        <div id="historyContainer" class="hidden max-w-5xl mx-auto mt-20">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                    <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Recent Sessions
                </h3>
            </div>
            <div id="historyList" class="flex flex-col gap-4">
                <!-- History cards injected here -->
            </div>
        </div>

        <!-- 2. Configuration & Margin Setup -->
        <div id="configContainer" class="hidden flex flex-col xl:flex-row gap-8 max-w-7xl mx-auto">
            <!-- Left Side: Combined Draggable Margins Preview -->
            <div class="flex-1 bg-white dark:bg-navy-900 p-6 rounded-2xl shadow-sm border border-gray-200 dark:border-navy-800 flex flex-col items-center">
                <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-6 w-full text-center">Visual Page Exclusion Margins</h3>
                
                <h4 class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-2 flex items-center justify-between w-full max-w-2xl">
                    <span>Global Header & Footer Crop</span>
                    <span class="text-xs text-red-500 font-semibold">Applies to ALL pages</span>
                </h4>
                
                <div class="relative inline-block border border-gray-300 dark:border-navy-600 rounded overflow-hidden select-none bg-gray-100 dark:bg-gray-800 max-w-2xl w-full">
                    <canvas id="firstPageCanvas" class="w-full h-auto block"></canvas>
                    <!-- Draggable Top Margin line -->
                    <div id="topLine" class="margin-line absolute left-0 right-0 h-8 -mt-4 top-[15%] flex items-center z-20">
                        <span class="absolute left-4 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded shadow pointer-events-none">TOP MARGIN (Header crop)</span>
                    </div>
                    <!-- Draggable Bottom Margin line -->
                    <div id="bottomLine" class="margin-line absolute left-0 right-0 h-8 -mt-4 bottom-[15%] flex items-center z-20">
                        <span class="absolute left-4 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded shadow pointer-events-none">BOTTOM MARGIN (Footer crop)</span>
                    </div>
                </div>
            </div>

            <!-- Right Side: Range Config and Scan Action -->
            <div class="w-full xl:w-96 flex flex-col space-y-6">
                <div class="bg-white dark:bg-navy-900 p-6 rounded-2xl shadow-sm border border-gray-200 dark:border-navy-800">
                    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Configuration</h3>
                    
                    <!-- Page Range Inputs -->
                    <div class="space-y-4 mb-6 border-b border-gray-200 dark:border-navy-700 pb-6">
                        <h4 id="pageRangeTitle" class="font-bold text-gray-800 dark:text-gray-200">Questions Setup</h4>
                        <div>
                            <label for="startPage" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start Page</label>
                            <input type="number" id="startPage" min="1" value="1" class="w-full px-3 py-2 text-base bg-white dark:bg-navy-950 border border-gray-300 dark:border-navy-600 text-gray-900 dark:text-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        </div>
                        <div>
                            <label for="endPage" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">End Page</label>
                            <input type="number" id="endPage" min="1" value="1" class="w-full px-3 py-2 text-base bg-white dark:bg-navy-950 border border-gray-300 dark:border-navy-600 text-gray-900 dark:text-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        </div>
                        <p class="text-xs text-gray-500 dark:text-gray-400" id="totalPagesText"></p>
                    </div>

                    <!-- Answer Key Location Choice -->
                    <div id="answerKeySourceContainer" class="space-y-4 mb-6">
                        <h4 class="font-bold text-gray-800 dark:text-gray-200">Answer Key Source</h4>
                        
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="answerKeySource" value="different" class="w-4 h-4 text-blue-600 focus:ring-blue-500" checked />
                                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Different PDF</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="answerKeySource" value="same" class="w-4 h-4 text-blue-600 focus:ring-blue-500" />
                                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Same PDF</span>
                            </label>
                        </div>
                    </div>

                    <!-- Trigger Actions -->
                    <div class="flex flex-col gap-3">
                        <button id="wizardNextBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-xl shadow-sm transition-colors flex items-center justify-center space-x-2">
                            <span>Next: Add Answer Key</span>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                        
                        <button id="wizardSkipScanBtn" class="hidden w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-4 rounded-xl shadow-sm transition-colors flex items-center justify-center space-x-2">

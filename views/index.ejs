    <div id="leaderboardModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="bg-white dark:bg-navy-900 rounded-3xl shadow-2xl max-w-3xl w-full overflow-hidden flex flex-col max-h-[90vh]">
            <!-- Header -->
            <div class="bg-gradient-to-r from-purple-600 to-blue-600 p-6 text-white relative">
                <h2 class="text-3xl font-extrabold text-center flex items-center justify-center gap-3">
                    <svg class="w-8 h-8 text-yellow-300" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2.5a.5.5 0 01.5.5v1.25l1.615.808a2 2 0 011.118 1.118l.808 1.615V9.5a.5.5 0 01-1 0V7.793l-.808-1.615a1 1 0 00-.559-.559L10 4.811 8.385 5.62a1 1 0 00-.559.559l-.808 1.615V9.5a.5.5 0 01-1 0V7.793l.808-1.615a2 2 0 011.118-1.118l1.615-.808V3a.5.5 0 01.5-.5zM5 11.5a.5.5 0 011 0V13h8v-1.5a.5.5 0 011 0V14a1 1 0 01-1 1H6a1 1 0 01-1-1v-2.5z" clip-rule="evenodd"></path></svg>
                    Live Practice Leaderboard
                </h2>
                <button id="closeLeaderboardBtn" class="absolute top-4 right-4 text-white/80 hover:text-white bg-white/10 hover:bg-white/20 p-2 rounded-full transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <!-- Table -->
            <div class="overflow-y-auto p-6 bg-gray-50 dark:bg-navy-950 flex-1">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-xs uppercase text-gray-500 dark:text-gray-400 border-b border-gray-200 dark:border-navy-700">
                            <th class="pb-3 font-semibold">Rank</th>
                            <th class="pb-3 font-semibold">Participant</th>
                            <th class="pb-3 font-semibold text-right">Score</th>
                            <th class="pb-3 font-semibold text-right">Accuracy</th>
                        </tr>
                    </thead>
                    <tbody id="leaderboardTbody" class="divide-y divide-gray-200 dark:divide-navy-800">
                        <!-- Leaderboard rows injected here -->
                    </tbody>
                </table>
            </div>
            
            <div class="p-6 bg-white dark:bg-navy-900 border-t border-gray-200 dark:border-navy-800 flex justify-center">
                <button id="exitLiveTestBtn" class="bg-gray-200 dark:bg-navy-800 hover:bg-gray-300 dark:hover:bg-navy-700 text-gray-800 dark:text-gray-200 font-bold py-2.5 px-8 rounded-xl transition-colors">
                    Exit to Home
                </button>
            </div>
        </div>
    </div>
    <script defer src="app.js?v=79"></script>
    <script defer src="/liveRoom.js"></script>
</body>
